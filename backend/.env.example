# =============================================================
# Strapi 5 — Environment Variables Template
# Copy to .env and fill in the actual values before running.
# On Plesk: set these in Node.js app environment variables panel.
# =============================================================

# -----------------------------------------------
# Server
# -----------------------------------------------
HOST=0.0.0.0
# PORT is assigned by Plesk automatically — leave blank or match Plesk setting
PORT=1337
NODE_ENV=production

# Public URL of the Strapi backend (used for media links, admin panel)
STRAPI_URL=https://api.best.tuke.sk

# Set to true if running behind Plesk reverse proxy (almost always true on Plesk)
IS_BEHIND_PROXY=true

# -----------------------------------------------
# CORS — comma-separated list of allowed frontend origins
# -----------------------------------------------
CORS_ORIGINS=https://best.tuke.sk

# -----------------------------------------------
# Strapi Secrets (generate unique values — never reuse from dev)
# Generate with: node -e "console.log(require('crypto').randomBytes(16).toString('base64'))"
# -----------------------------------------------
APP_KEYS=CHANGE_ME_key1,CHANGE_ME_key2,CHANGE_ME_key3,CHANGE_ME_key4
API_TOKEN_SALT=CHANGE_ME
ADMIN_JWT_SECRET=CHANGE_ME
TRANSFER_TOKEN_SALT=CHANGE_ME
ENCRYPTION_KEY=CHANGE_ME

# -----------------------------------------------
# Database — PostgreSQL (Plesk → Databases panel)
# -----------------------------------------------
DATABASE_CLIENT=postgres
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=CHANGE_ME_db_name
DATABASE_USERNAME=CHANGE_ME_db_user
DATABASE_PASSWORD=CHANGE_ME_db_password
# Set to true only if your Plesk PostgreSQL requires SSL
DATABASE_SSL=false
